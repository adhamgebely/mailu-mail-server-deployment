# ===============================
# General configuration
# ===============================

DOMAIN=example.com
HOSTNAMES=mail.example.com

POSTMASTER=postmaster

# ===============================
# TLS / Security
# ===============================

TLS_FLAVOR=letsencrypt
AUTH_RATELIMIT=10/minute

# ===============================
# Admin account
# ===============================

MAILU_ADMIN=admin
MAILU_ADMIN_PW=REDACTED_PASSWORD

# ===============================
# Database / Secrets
# ===============================

SECRET_KEY=REDACTED_SECRET_KEY

# ===============================
# Mail settings
# ===============================

SUBNET=192.168.203.0/24

# Enable anti-spam & antivirus (optional in Mailu setup)
ANTIVIRUS=none
SPAMFILTER=on

# ===============================
# Webmail
# ===============================

WEBMAIL=roundcube

# ===============================
# Logging / Debug
# ===============================

LOG_LEVEL=INFO
